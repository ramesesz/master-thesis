        <rdfs:comment>The set of airports in the continental US.</rdfs:comment>
        <rdfs:label>Continental US airport</rdfs:label>
    </owl:Class>
    


    <!-- https://data.nasa.gov/ontologies/atmonto/NAS#CanadianAirport -->

    <owl:Class rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#CanadianAirport">
