    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>published arrival time</rdfs:label>
    <rdfs:comment>The time that the flight is planned to arrive per the OAG schedule.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#Flight"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb147">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>MEDIUM</rdf:first>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb132">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>NonCONUS</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb133"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb159">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb160"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#aircraftWeightCat"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#associatedAirport">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>associated airport</rdfs:label>
    <rdfs:comment>Associates some component of airport infrastructure (runway, terminal, tower, etc.) with its airport.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirportInfrastructureComponent"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#Region3D">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>A three-dimensional geographic region.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#GeographicRegion"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#includesARTCC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>includes ARTCC</rdfs:label>
    <rdfs:comment>A link between an ARTCC tier and the ARTCCs included in the tier.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#ARTCCtier"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#ARTCC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#manufacturerCountryName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>manufacturer country name</rdfs:label>
    <rdfs:comment>The country name where the manufacturer is established.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirframeManufacturer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#Aircraft">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aircraft</rdfs:label>
    <rdfs:comment>A physical realization of an aircraft, produced according to the specifications defined for a specific model type.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb148"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#DecomposableSystem"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#SequencedItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#KDFWcoordinates">
    <rdf:type rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#PointLocation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">KDFW coordinates</rdfs:label>
    <gen:altitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">607.0</gen:altitude>
    <gen:latitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">32.897231</gen:latitude>
    <gen:longitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">-97.037694</gen:longitude>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#includedFlights">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>included flights</rdfs:label>
    <rdfs:comment>Links an aircraft flow to a specification of the flights included in the flow.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftFlow"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#FlightSpec"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#QRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Q-Route</rdfs:label>
    <rdfs:comment>A high altitude RNAV airway route. (RNAV routes allow an aircraft to choose any course within a network of navigation beacons, rather than navigate directly to and from the beacons.)</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#RNAVroute"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb133">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>US</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb134"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#aircraftWeightCat">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>aircraft weight category</rdfs:label>
    <rdfs:comment>Indicates the weight category as part of a flight specification constraint.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#FlightSpec"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb101">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>ROUTE</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb102"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#subsequenceEndIndex">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>subsequence end index</rdfs:label>
    <rdfs:comment>A numeric position within a base sequence that represents the end of the subsequence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#SubSequence"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftFlowCapacity">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aircraft flow capacity</rdfs:label>
    <rdfs:comment>A subclass of interval-based data representing the maximum controllable number of aircraft flowing through an airspace region during some interval of time, given weather and other air traffic control constraints.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#EngineType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Engine Type</rdfs:label>
    <rdfs:comment>Represents different generic types of aircraft engines.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#routeID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>route ID</rdfs:label>
    <rdfs:comment>FAA alphanumeric identifier assigned to the route/airway.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirspaceRoute"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#departureAirport">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>departure airport</rdfs:label>
    <rdfs:comment>Links to the actual departure airport for the flight.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#Flight"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#SID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Standard Instrument Departure</rdfs:label>
    <rdfs:comment>A SID (Standard Instrument Departure) is an air traffic control coded departure procedure that has been established at certain airports to simplify clearance delivery procedures.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#SIDSTAR"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftWeightClass">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aircraft Weight Class</rdfs:label>
    <rdfs:comment>Specifies a category of aircraft that can be used to partition aircraft according to their weight.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb30">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#ProgramArrivalRateContainer"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#hasSequencedItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#ATCSCC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>ATCSCC</rdfs:label>
    <rdfs:comment>Air Traffic Control System Command Center (ATCSCC) facility</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#NASfacility"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasAirspaceLayerGeometry">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has airspace layer geometry</rdfs:label>
    <rdfs:comment>Links an airspace layer with a polygon describing its location in 3-space. A sector is composed of a sequence of layers, each of which is represented as a shear-sided polygonal volume.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirspaceLayer"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#ShearSidedPolygonalVolume"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#ProgramArrivalRateSequence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Program Arrival Rate Sequence</rdfs:label>
    <rdfs:comment>An ordered sequence of hourly program arrival rates used in specifying a Ground Dela Program (GDP).</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb29"/>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb30"/>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb31"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#Sequence"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb19">
    <rdf:first rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#OperationalRunway"/>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb20"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#fixTrajectoryString">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>fix trajectory string</rdfs:label>
    <rdfs:comment>This is an experimental property of a flight that stores an ordered sequence of named fixes corresponding one-to-one to the sequence of trajectory track points recorded for the flight. For a given track point, the corresponding named fix is computed by finding the closest named fix to the track point.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#Flight"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#TransitionRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Transition route</rdfs:label>
    <rdfs:comment>A route within a SID or STAR that feeds aircraft into or out from the common route of the SID/STAR. In other words, the transition route is a feeder route from the en route segment of a flight into the heart of a STAR for arrival; or an exit route from a SID funneling flights to their appropriate initial jet routes for the en route segment of flight.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#SIDSTARroute"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#centerpoint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>centerpoint</rdfs:label>
    <rdfs:comment>Links to the center point of the 2-D circular region.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#CircularRegion"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#PointLocation"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasTRACONstate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has TRACONstate</rdfs:label>
    <rdfs:comment>The name of the US state in which the TRACON command center is located.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#TRACON"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#sequenceNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>sequenceNumber</rdfs:label>
    <rdfs:comment>Indicates the ordered position of this item within the sequence, where 1 signifies the first position in the sequence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#SequencedItem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#aircraftCount">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>aircraft count</rdfs:label>
    <rdfs:comment>The number of aircraft flowing through an airspace region per some interval of time.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftFlow"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb2">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#PlannedFlightRoute"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#subsequenceOf"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#airspaceLayerHighAltitude">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>airspace layer high altitude</rdfs:label>
    <rdfs:comment>The upper altitude bound of an airspace layer.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirspaceLayer"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#modeledArrivalRate">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>modeled arrival rate</rdfs:label>
    <rdfs:comment>Links a delay model used in defining a Ground Delay Program (GDP) or Ground Stop(GS) to a sequence of desired hourly aircraft arrival rates specified for the initiative.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#DelayModel"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#ProgramArrivalRateSequence"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#hasPolygonBoundary">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has polygon boundary</rdfs:label>
    <rdfs:comment>Links a polygonal region to its boundary representation.</rdfs:comment>
    <rdfs:domain rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb23"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#PolygonBoundary"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb142">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>UDP</rdf:first>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationSubPath">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Navigation SubPath</rdfs:label>
    <rdfs:comment>A contiguous portion of an existing navigation path.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationElement"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#SubSequence"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#JetRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Jet route</rdfs:label>
    <rdfs:comment>A high altitude airway based on ground-based VOR sensor locations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#VORroute"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb109">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>OTHER</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb110"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasTower">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has tower</rdfs:label>
    <rdfs:comment>Links an airport to an air traffic control tower for that airport.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#ATCT"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#airCarrierName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>Air carrier name</rdfs:label>
    <rdfs:comment>The official name of an air carrier.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirCarrier"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb3">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb4"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb59">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#extensionProbability"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb165">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
    <owl:oneOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb166"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#effectiveStartDay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>effective start day</rdfs:label>
    <rdfs:comment>Links to the expected starting day of the traffic management initiative (TMI).</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#TrafficManagementInitiative"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#NASday"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#hasAircraftModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
