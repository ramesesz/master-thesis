  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftNavigationSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aircraft navigation system</rdfs:label>
    <rdfs:comment>An aircraft subsystem responsible for navigation functions.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftSubsystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#aircraftRegistrant">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>aircraft registrant</rdfs:label>
    <rdfs:comment>The name of the entity that registered the aircraft with the FAA.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#Aircraft"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#VORfix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>VOR Fix</rdfs:label>
    <rdfs:comment>A fix based on the location of a ground-based VOR (VHF Omni Directional Radio Range) installation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavaidFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#userCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>user category</rdfs:label>
    <rdfs:comment>The type of airspace user that this flight represents: GA, Air Taxi, Cargo, Commercial, Military. Also used to constrain a flight specification to contain only flights representing a specific user category.</rdfs:comment>
    <rdfs:domain rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb63"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#KSEAairport">
