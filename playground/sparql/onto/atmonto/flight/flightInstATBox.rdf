    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#Location"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#longitude">
