  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#reportingTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>reporting time</rdfs:label>
    <rdfs:comment>The time when an en route aircraft passed through a trackpoint and reported its position, speed, and heading.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftTrackPoint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#FloatParameter">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Float parameter</rdfs:label>
    <rdfs:comment>A subclass of NumericParameter representing parameters with floating-point values.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb22"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#NumericParameter"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#aircraftTypeFlown">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>aircraft type flown</rdfs:label>
    <rdfs:comment>Links a flight with the type of aircraft flown. The aircraft 'type' corresponds to a set of aircraft models with similar characteristics.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#Flight"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#runwayLengthInFeet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>runway length in feet</rdfs:label>
    <rdfs:comment>The length in feet of the physical runway.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#PhysicalRunway"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#CONUSairport">
