  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#VORroute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>VOR route</rdfs:label>
    <rdfs:comment>A VOR route is defined relative to a network of existing ground-based VOR navigation beacons. VOR routes consist of point-to-point segments, where the points are defined by the beacons. More modern RNAV routes allow any path within the network, not limited to VOR-to-VOR segments.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#FederalAirway"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb10">
    <rdf:first rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#GroundDelayProgramTMI"/>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb11"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#ReRouteSegment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>ReRoute segment</rdfs:label>
    <rdfs:comment>One of the route segment alternatives specified as part of a ReRoute traffic management initiative (TMI).</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb66"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#VictorRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Victor route</rdfs:label>
    <rdfs:comment>A low altitude airway based on ground-based VOR sensor locations.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#VORroute"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:versionInfo>Created with TopBraid Composer</owl:versionInfo>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb34">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#Aircraft"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#hasFirstItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#radialFix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>radial fix</rdfs:label>
    <rdfs:comment>Links to the fix through which the radial route passes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#RadialRoute"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#AirspaceInfrastructureComponent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Airspace infrastructure component</rdfs:label>
    <rdfs:comment>A defined substructure of the airspace used to manage air traffic, including sectors, SIDs, STARs, routes, etc.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#TFMcontrolElement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#closedStartTimeInterval">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>closed start time interval</rdfs:label>
    <rdfs:comment>A boolean property that specifies whether or not the starting point of the time interval is closed (inclusive of the point).</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#TimeInterval"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#ProgramArrivalRateContainer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Program arrival rate container</rdfs:label>
    <rdfs:comment>A wrapper around a program arrival rate, used to sequence them into an ordered list.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb62"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NumericParameterContainer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#GDPmodel">
    <rdfs:comment>This model provides parameters to the code that assigns times to the aircraft involved in the GDP or GS</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#Terminal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Terminal</rdfs:label>
    <rdfs:comment>A structure on the airport surface that serves as an interface between people, baggage, and aircraft.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirportInfrastructureComponent"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasRampTower">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has ramp tower</rdfs:label>
    <rdfs:comment>Associates an airport terminal with a ramp tower that controlls the aircraft and vehicle traffic in the vicinity of that terminal.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Terminal"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#RampTower"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb22">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#parameterValue"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb181">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>GA</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb182"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#includesAirport">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>includes airport</rdfs:label>
    <rdfs:comment>Links an airport specification to one of more airports. Any airport linked is included in the set of airports covered by this airport specification. This property allows for explicit specification of a list of specific airports; the property atm:includesAirportType allows for the the implicit specification of an entire class of airports.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AirportSpec"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftFlow">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aircraft flow</rdfs:label>
    <rdfs:comment>A subclass of interval-based data representing the number of aircraft flowing through an airspace region during some interval of time.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftFlowCapacity"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb90">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>FCA Flight List</rdf:first>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftModel">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aircraft model</rdfs:label>
    <rdfs:comment>An aircraft model represents a generic specification that describes the characteristics of a specific type of aircraft to be manufactured.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationFix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Navigation fix</rdfs:label>
    <rdfs:comment>A designated point on the surface of the earth used for aeronautical navigation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationElement"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb81">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
    <owl:oneOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb82"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#manufacturedBy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
