  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb15">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb16"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#excludesAirport">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>excludes airport</rdfs:label>
    <rdfs:comment>Links an airport specification to one of more airports. Any airport linked is excluded from the set of airports covered by this airport specification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AirportSpec"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/flightInst">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <owl:imports rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb116">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>LOW</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb117"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb150">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
    <owl:oneOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb151"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#ElectricalPowerSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Electrical power system</rdfs:label>
    <rdfs:comment>An aircraft subsystem responsible for generating and distributing electrical power.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftSubsystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#aircraftTypeDesignator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>aircraft type designator</rdfs:label>
    <rdfs:comment>The type designator code for this type of aircraft (e.g., B777).</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#hasNavElement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has navigation element</rdfs:label>
    <rdfs:comment>Links a container for a navigational element to the element contained.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavElementContainer"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationElement"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb13">
    <rdf:first rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#GroundDelayProgramTMI"/>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb14"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#plannedDepartureDay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>planned departure day</rdfs:label>
    <rdfs:comment>Links to the day that the flight is planned to depart per the flight plan.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#Flight"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#NASday"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#reRouteConstraint">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>reroute constraint</rdfs:label>
    <rdfs:comment>Links a route segment specified as part of a ReRoute traffic management initiative (TMI) to a flight specification indicating which flights are permitted to follow the route segment.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#ReRouteSegment"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#FlightSpec"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasSectorLayer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has sector layer</rdfs:label>
    <rdfs:comment>Links a sector to its vertically-stacked set of layers.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Sector"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirspaceLayer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftSubsystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aircraft subsystem</rdfs:label>
    <rdfs:comment>An engineering subsystem of an aircraft.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#DecomposableSystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#planGapAfterSequenceElementNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>plan gap after sequence element number</rdfs:label>
    <rdfs:comment>Indicates the location of a gap in the flight plan due to non-parsable/uninterpretable elements in the flight plan string.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#PlannedFlightRoute"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftWakeCategory">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aircraft Wake Category</rdfs:label>
    <rdfs:comment>Specifies a category of aircraft according to their wake turbulance characteristics (including takeoff weight and wingspan). These categories are useful for the purpose of FAA separation assurance. See FAA Order JO 7110.659B, Wake Turbulence Recategorization, effective March 01, 2015.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#SequencedItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Sequenced item</rdfs:label>
    <rdfs:comment>The set of items that can be sequenced.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#manufactureYear">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>manufacture year</rdfs:label>
    <rdfs:comment>The year the system was manufactured.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#EngineeredSystem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#iataAirportCode">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>IATA Airport Code</rdfs:label>
    <rdfs:comment>The thre-letter IATA code assigned to the airport. Contrast with the ICAO and FAA airport codes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#initiativeComments">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:comment>Provides any specific comments on the traffic management initiative (TMI) made by the issuing authority (e.g., ATCSCC, ARTCC).</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#TrafficManagementInitiative"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb106">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb107"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#reRouteReason"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb50">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>MEDIUM</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb51"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#planFilingDay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>plan filing day</rdfs:label>
    <rdfs:comment>Links to the day when the flight plan was filed with the FAA.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#PlannedFlightRoute"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#NASday"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb129">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>CONUS</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb130"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#excludesAirway">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>excludes airway</rdfs:label>
    <rdfs:comment>Links a flight specification to one of more airways (routes). Any flight that traverses a linked airway is excluded from the set of flights covered by this flight specification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#FlightSpec"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirspaceRoute"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#aircraftFix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>aircraft fix</rdfs:label>
    <rdfs:comment>Links an aircraft track point with its associated navigation fix.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftTrackPoint"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#ActualFlightRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Actual Flight Route</rdfs:label>
    <rdfs:comment>A flight trajectory (i.e., a sequence of track points), as determined by flight track surveillance data.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb135"/>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb136"/>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb137"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#Sequence"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb91">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb92"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#reRouteType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#Polygonal2DRegion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment>A two-dimensional region defined by a polygonal boundary.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#Region2D"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#modeledTotalDelay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>modeled total delay minutes</rdfs:label>
    <rdfs:comment>The total flight delay specified when modeling a Ground Delay Program (GDP) or Ground Stop(GS).</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#DelayModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#ShearSidedPolygonalVolume">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Shear sided polygonal volume</rdfs:label>
    <rdfs:comment>A three-dimensional volume defined by a two-dimensional polygon plus a length component that stretches the polygon along an axis perpendicular to the polygon surface.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#Region3D"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#Sequence">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Sequence</rdfs:label>
    <rdfs:comment>An ordered sequence of items.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#timeConstraintType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>time constraint type</rdfs:label>
    <rdfs:comment>Specifies the type of flight time being constrained in this flight specification: either ETA (estimated arrival time) or ETD (estimated departure time).</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#FlightSpec"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb42">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Taxiway"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#hasFirstItem"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb29">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#ProgramArrivalRateContainer"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#hasFirstItem"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb123">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb124"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#hasTRACONtype"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb89">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>ETD</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb90"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#ASAairline">
    <rdf:type rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirCarrier"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alaska Airlines</rdfs:label>
    <nas:airCarrierName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alaska Airlines</nas:airCarrierName>
    <nas:airlineCallsign rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ALASKA</nas:airlineCallsign>
    <nas:countryOfRegistry rdf:datatype="http://www.w3.org/2001/XMLSchema#string">United States</nas:countryOfRegistry>
    <nas:iataCarrierCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">AS</nas:iataCarrierCode>
    <nas:icaoCarrierCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">ASA</nas:icaoCarrierCode>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb166">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>All</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb167"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#RunwayVisibleRangeMeasurement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>RVR measurement</rdfs:label>
    <rdfs:comment>A measurement of the distance over which a pilot of an aircraft on the centerline of a runway can see the runway surface markings delineating the runway and its centerline. RVR (Runway Visible Range) is expressed as an interval specifying the minimum and maximum number of feet visible.</rdfs:comment>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb23">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:unionOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb24"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#TACANfix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>TACAN Fix</rdfs:label>
    <rdfs:comment>A fix based on the location of a ground-based TACAN (TACtical Air Navigation) installation.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavaidFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#locatedInState">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>Located in State</rdfs:label>
    <rdfs:comment>The 2-letter US postal code for the state in which the airport is located.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#adjacentSector">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>adjacent sector</rdfs:label>
    <rdfs:comment>Links a sector to an immediately adjacent sector that shares a boundary.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Sector"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Sector"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#mustHaveOrigin">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>must have origin</rdfs:label>
    <rdfs:comment>Links a flight specification to an airport specification describing the originating airports for the flights being specified. Any flight covered by the flight specification must have as its origin one of the airports covered by the airport specification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#FlightSpec"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AirportSpec"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#RadialRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Radial Route</rdfs:label>
    <rdfs:comment>A route that follows a specified radial path emanating from a given fix.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirspaceRoute"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb75">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>other</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb76"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb66">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb67"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#reRouteSegmentType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#heading">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>heading</rdfs:label>
    <rdfs:comment>The aircraft heading at the track point: a number between 0.01 and 360.0 indicating the angular heading with respect to North.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftTrackPoint"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb175">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#timeConstraintType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#PopupFactor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Popup factor</rdfs:label>
    <rdfs:comment>Factor to account for late-filing flights when modeling delays as part of a traffic management initiative (TMI) design process.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#IntegerParameter"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasTRACONname">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has TRACON name</rdfs:label>
    <rdfs:comment>The common name for the TRACON.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#TRACON"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb130">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>Canadian</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb131"/>
  </rdf:Description>
  <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#time">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb58">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>weather</rdf:first>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#exemptedAFP">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>exempted AFP</rdfs:label>
    <rdfs:comment>Links a flight specification to one of more Airspace Flow Program (AFP) traffic management initiatives (TMIs). Any flight included in one of the linked AFPs is excluded from the set of flights covered by this flight specification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#FlightSpec"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AirspaceFlowProgramTMI"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#Flight">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Flight</rdfs:label>
    <rdfs:comment>A single flight segment from origin to destination.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb176"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb119">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#reRouteType"/>
