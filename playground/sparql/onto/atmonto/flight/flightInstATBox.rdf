  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#SIDSTARtraverse">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>SIDSTARtraverse</rdfs:label>
    <rdfs:comment>A route through a SID (Standard Instrument Departure route) or a STAR (Standard Arrival Route), traversing a common route at minimum and optionally a transition route and/or an airport route.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationElement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#hasNextItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasNext</rdfs:label>
    <rdfs:comment>Links an item in a sequence to the subsequent item in the sequence.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#SequencedItem"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#SequencedItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#arrivalRouteAirport">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>arrival route airport</rdfs:label>
    <rdfs:comment>Links to the airport for which this route is destined.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirportRoute"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb76">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>runway</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb77"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#EGLLairport">
    <rdf:type rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#InternationalAirport"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EGLL Airport</rdfs:label>
    <nas:airportLocation rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#EGLLcoordinates"/>
    <nas:airportName rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Heathrow</nas:airportName>
    <nas:iataAirportCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">LHR</nas:iataAirportCode>
    <nas:icaoAirportCode rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EGLL</nas:icaoAirportCode>
    <nas:withinTimezone rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Europe/London</nas:withinTimezone>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#KSFOcoordinates">
    <rdf:type rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#PointLocation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">KSFO coordinates</rdfs:label>
    <gen:altitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">13.0</gen:altitude>
    <gen:latitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">37.619106</gen:latitude>
    <gen:longitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">-122.375236</gen:longitude>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasAirportRoute">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has airport route</rdfs:label>
    <rdfs:comment>Associates an airport route with a SID or STAR. A SID or STAR has a single common route, but can have multiple airport or transition routes.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#SIDSTAR"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirportRoute"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#AirportInfrastructureComponent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Airport infrastructure component</rdfs:label>
    <rdfs:comment>Part of an airport's physical infrastructure, including gates, terminals, runways, taxiways, etc.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb28">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#PopupFactorContainer"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#hasLastItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#RelativeFix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Relative fix</rdfs:label>
    <rdfs:comment>A fix defined in relation to another fix.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#prevTotalDelay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>previous total delay minutes</rdfs:label>
    <rdfs:comment>The total flight delay experienced prior to the start of a Ground Stop(GS).</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#DelayModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb8">
    <rdf:first rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#ARTCCtier"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#MilesInTrailTMI">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Miles in Trail (MIT)</rdfs:label>
    <rdfs:comment>A Miles-in-Trail (MIT) traffic management initiative (TMI) is used to apportion traffic into a manageable flow, as well as provide space for additional traffic (merging or departing) to enter the flow of traffic. Miles-in-trail describes the number of miles required between aircraft departing an airport, over a fix, at an altitude, through a sector, or on a specific route.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#TrafficManagementInitiative"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb37">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#PointLocation"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#hasSequencedItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#IntersectionFix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Intersection fix</rdfs:label>
    <rdfs:comment>A navigation fix defined by the intersection of two airspace routes.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AbsoluteFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#radius">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>radius</rdfs:label>
    <rdfs:comment>The radius of a circular region. Note: Unfortunately, the units are currently dependent the type of circular region defined. This needs to be improved.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#CircularRegion"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb154">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>GA</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb155"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#FRDfix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>FRD Fix</rdfs:label>
    <rdfs:comment>A Fix Radial Distance (FRD) fix is located a specified distance from a ground-based navaid, a named fix, or an airport, along a given radial vector.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#RelativeFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#GPSfix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>GPS fix</rdfs:label>
    <rdfs:comment>A navigation fix defined by GPS coordinates.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#LatLonFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#withinAirportBoundingRegion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>within airport bounding region</rdfs:label>
    <rdfs:comment>Links an airport specification to a circular geographic region. Only airports whose locations fall within this region satisfy the specification.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AirportSpec"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#CircularRegion"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#airCarrierAlias">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>air carrier alias</rdfs:label>
    <rdfs:comment>An alternative name for an air carrier.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirCarrier"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#EngineeredSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Engineered system</rdfs:label>
    <rdfs:comment>Represents engineered systems as either decomposable or non-decomposible subsystems.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#AviationIndustryManufacturer">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Aviation industry manufacturer</rdfs:label>
    <rdfs:comment>A superclass encompassing the set of airframe and engine manufacturers.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AviationServiceProvider"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb134">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>all</rdf:first>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#isAircraftType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>is aircraft type</rdfs:label>
    <rdfs:comment>Links an aircraft model to its type, where the type represents a set of related models.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftModel"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#AircraftType"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/equipment#aircraftSerialNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>serial number</rdfs:label>
    <rdfs:comment>The manufacturer serial number of the aircraft.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/equipment#Aircraft"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb128">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
    <owl:oneOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb129"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#NASday">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>NAS day</rdfs:label>
    <rdfs:comment>A class that represents a day of the year. Events, such as flights, weather forecasts, and other events are linked to the instance of the day they occurred.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#CYYZcoordinates">
    <rdf:type rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#PointLocation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">CYYZ coordinates</rdfs:label>
    <gen:altitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">569.0</gen:altitude>
    <gen:latitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">43.676661</gen:latitude>
    <gen:longitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">-79.630644</gen:longitude>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb44">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#parameterValue"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#ARTCC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>ARTCC</rdfs:label>
    <rdfs:comment>Air Route Traffic Control Center (ARTCC or 'Center') facility</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirspaceInfrastructureComponent"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#NASfacility"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasRunway">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>has runway</rdfs:label>
    <rdfs:comment>Links an airport to a physical runway for that airport.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#PhysicalRunway"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb136">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftTrackPoint"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#hasFirstItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasSectorName">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has sector name</rdfs:label>
    <rdfs:comment>An alphanumeric sector name that is in general different than the sector ID.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Sector"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb87">
    <rdf:type rdf:resource="http://www.w3.org/2000/01/rdf-schema#Datatype"/>
    <owl:oneOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb88"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb20">
    <rdf:first rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#PhysicalRunway"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#AirspaceRouteSegment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Airspace route segment</rdfs:label>
    <rdfs:comment>A contiguous portion of an existing airspace route.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb1"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#NavigationSubPath"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb25">
    <rdf:first rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#ShearSidedPolygonalVolume"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#isWeatherReportingStation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>is weather reporting station</rdfs:label>
    <rdfs:comment>Indicates whether this airport is a METAR weather reporting station.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#prevAverageDelay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>previous average delay minutes</rdfs:label>
    <rdfs:comment>The average flight delay experienced prior to the start of a Ground Stop(GS).</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#DelayModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#OperationalRunway">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Operational runway</rdfs:label>
    <rdfs:comment>An operational runway is a named runway one used in airport operations. There are two operational runways corresponding to one physical runway; these operational runways are 180 degrees apart.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#AirportInfrastructureComponent"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#hasSectorID">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>has sector ID</rdfs:label>
    <rdfs:comment>A sector identifier that consists of the ARTCC identifier concatenated with a three-digit number. This identifier is in general different than the sector name.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Sector"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#flowMeasurementRegion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>flow measurement region</rdfs:label>
    <rdfs:comment>Links an aircraft capacity or aircraft flow to the spatial region through which flow or capacity is being monitored and measured.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AircraftFlowCapacity"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#TFMcontrolElement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#hasFirstItem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>hasFirstItem</rdfs:label>
    <rdfs:comment>Links a sequence to the first item being sequenced.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#Sequence"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#SequencedItem"/>
    <rdfs:subPropertyOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#hasSequencedItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#endTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>end time</rdfs:label>
    <rdfs:comment>The ending time of a defined time interval.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#TimeInterval"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#impactingCondition">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>impacting condition</rdfs:label>
    <rdfs:comment>Indicates the reason for initiating the Ground Delay Program: weather, volume, runway, equipment, other.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#GroundDelayProgramTMI"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#adlDay">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>adl day</rdfs:label>
    <rdfs:comment>Links a delay model to the day that the ADL (Aggregate Demand List) was generated. Each ADL contains information on the flights arriving and departing from an airport, or entering into and departing from a flow area.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#DelayModel"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#NASday"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#StandAloneWeatherStation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Stand-alone weather station</rdfs:label>
    <rdfs:comment>A non-airport location where operational weather monitoring hardware is installed.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb4">
    <rdf:first rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#GroundDelayProgramTMI"/>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb5"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#withinARTCC">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>within ARTCC</rdfs:label>
    <rdfs:comment>Links the airport to the ARTCC within which it is located.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#Airport"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/NAS#ARTCC"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#NRSfix">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>NRS fix</rdfs:label>
    <rdfs:comment>The NRS is a system of waypoints developed for use within the United States for flight planning and navigation without reference to ground based navigational aids. The NRS waypoints are located in a grid pattern along defined latitude and longitude lines. NRS waypoint names are composed of two letters followed by two numbers, followed by a single letter. The first and second characters of NRS waypoints are the FIR identifier for the United States (“K”) and the FIR subdivision, or ARTCC center in which the waypoint is located (e.g. “D” for Denver ARTCC). The third and fourth characters are a number group representing the latitude of the waypoint. These numbers begin at the equator with 00 and advances north and south from 01 to 90 and correspond to every 10 minutes of latitude and repeating every 15°. The final character in the NRS waypoint is a letter representing the line of longitude for which the waypoint is located. This identifier starts at the prime meridian moving west to east and uses the letters A to Z while repeating every 26°. To date, the current density of the NRS grid is one waypoint spaced every 30 minutes of latitude and every 2° of longitude.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#LatLonFix"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#Taxipath">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Taxipath</rdfs:label>
    <rdfs:comment>A sequence of taxiways followed by an aircraft taxiing en route to/from a runway.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb41"/>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb42"/>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb43"/>
    <rdfs:subClassOf rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#Sequence"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb164">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb165"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#includesAircraftClass"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb131">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>International</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb132"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb60">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#controlledNASelement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#departureScope">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:label>departure scope</rdfs:label>
    <rdfs:comment>Links a Ground Delay Program (GDP) or a Ground Stop (GS) to a specification of the departure airport(s) participating in the traffic management initiative (TMI).</rdfs:comment>
    <rdfs:domain rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb3"/>
    <rdfs:range rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#AirportSpec"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/general#startTime">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label>start time</rdfs:label>
    <rdfs:comment>The starting time of a defined time interval.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#TimeInterval"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#reRouteType">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:label>ReRoute type</rdfs:label>
    <rdfs:comment>The ReRoute type encodes information about the type of ReRoute being initiated or the reason for the ReRoute. One of the following: ROUTE , PLAYBOOK , CDR, SPECIAL OPERATIONS, NRP SUSPENSIONS, VS , NAT, SHUTTLE ACTIVITY, FCA, FEA, INFORMATIONAL, MISCELLANEOUS.</rdfs:comment>
    <rdfs:domain rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#ReRouteTMI"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/NAS#KJFKcoordinates">
    <rdf:type rdf:resource="https://data.nasa.gov/ontologies/atmonto/general#PointLocation"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">KJFK coordinates</rdfs:label>
    <gen:altitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">14.0</gen:altitude>
    <gen:latitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">40.63975</gen:latitude>
    <gen:longitude rdf:datatype="http://www.w3.org/2001/XMLSchema#float">-73.778925</gen:longitude>
  </rdf:Description>
  <rdf:Description rdf:about="https://data.nasa.gov/ontologies/atmonto/ATM#AirportSpec">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label>Airport spec</rdfs:label>
    <rdfs:comment>A specification of a set of airports.</rdfs:comment>
    <rdfs:subClassOf rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb127"/>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb152">
    <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
    <rdf:first>Cargo</rdf:first>
    <rdf:rest rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb153"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb113">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb114"/>
    <owl:onProperty rdf:resource="https://data.nasa.gov/ontologies/atmonto/ATM#extensionProbability"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n2f1058e89ded4aecb53eb2b9ceadfb8cb52">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
